# Keep the Docker build context lean and reproducible. Without this, `COPY . .`
# would overlay the host's (possibly cross-platform) node_modules — whose native
# binaries (rolldown/esbuild) differ by OS — onto the clean `npm ci` install and
# could break `vite build` inside the image.
node_modules
dist
coverage
.env
*.log
.git
.gitignore
Dockerfile
.dockerignore
npm-debug.log*
