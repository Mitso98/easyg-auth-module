# Backend environment — copy to `.env` and fill in real values.
# `.env` is gitignored; this template is committed.

NODE_ENV=development
PORT=3000

# In Docker, `mongo` is the compose service name. For local (non-Docker)
# dev against the compose Mongo, use mongodb://localhost:27017/auth
MONGO_URI=mongodb://mongo:27017/auth

# Secret used to sign JWTs. Generate one with:
#   openssl rand -base64 48
JWT_SECRET=

JWT_EXPIRES_IN=15m

# Comma-separated list of allowed origins. Not needed in the same-origin
# Docker setup (nginx proxies /api), but useful for direct local dev.
CORS_ORIGINS=http://localhost:5173

LOG_LEVEL=info
